{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "garden-battle-mini-app": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "gb",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/garden-battle-mini-app",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/assets"],
            "styles": ["src/theme/variables.scss", "src/styles.scss"]
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "garden-battle-mini-app:build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "a95539c8-6436-48fe-a6ed-0db663da5688"
  }
}
