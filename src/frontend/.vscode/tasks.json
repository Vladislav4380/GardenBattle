{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: start",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "start"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "backend: api",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "../backend/src/GardenBattle.Api/GardenBattle.Api.csproj",
        "--launch-profile",
        "http"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
